{
  "name": "@hermes-desktop/config-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx watch server.ts\"",
    "build": "vite build && tsc server.ts --outDir dist --module ESNext --target ES2020 --moduleResolution bundler --esModuleInterop",
    "preview": "vite preview",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "js-yaml": "^4.1.0",
    "better-sqlite3": "^9.2.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.5",
    "@types/better-sqlite3": "^7.6.8",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "svelte": "^4.2.8",
    "@sveltejs/vite-plugin-svelte": "^3.0.1",
    "tailwindcss": "^3.4.1",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.33",
    "concurrently": "^8.2.2",
    "tsx": "^4.7.0"
  }
}
