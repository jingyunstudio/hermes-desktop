# 本地开发配置示例
# 复制此文件为 .env.local 并填入你的配置

# Jingyun 服务地址配置
JINGYUN_BASE_URL=http://localhost:8888
JINGYUN_USER_APP_HERMES_URL=http://localhost:3000/hermes
# 多租户模式可选：显式指定租户 slug（为空时按域名解析）
JINGYUN_TENANT_SLUG=

# Docker 镜像源配置（可选，留空则使用公共镜像源）
HERMES_IMAGE=
OPENWEBUI_IMAGE=

# Docker Desktop 下载备用源（可选）
DOCKER_DESKTOP_BACKUP_URL=
