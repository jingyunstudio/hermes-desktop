{
  "name": "desktop-shell",
  "version": "0.1.1",
  "private": true,
  "description": "Hermes Desktop configuration and operations shell",
  "author": "Jingyun",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --config vite.renderer.config.ts\" \"tsc -p tsconfig.main.json --watch\" \"tsc -p tsconfig.preload.json --watch\" \"wait-on tcp:5173 && cross-env DESKTOP_RENDERER_URL=http://localhost:5173 electron .\"",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "lint": "echo \"TODO lint\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hermes-desktop/deploy-engine": "workspace:*",
    "@hermes-desktop/runtime-adapter": "workspace:*",
    "@hermes-desktop/shared-types": "workspace:*",
    "express": "^4.22.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^22.7.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.0.2",
    "electron-builder": "^25.1.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.8",
    "wait-on": "^8.0.1"
  }
}
